# F1 Oracle v4.1 — Environment Variables
# Copy this file to .env and fill in your values

# Discord webhook URL (required for alerts)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Logging
LOG_LEVEL=info       # debug | info | warn | error
LOG_FORMAT=pretty    # pretty (dev) | json (production/GitHub Actions)

# Database path (optional, defaults to data/f1_oracle.db)
# DB_PATH=data/f1_oracle.db

# Number of simulations (optional, defaults to 10000)
# SIMS=10000
